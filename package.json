{
  "name": "coffeeshop-zerno",
  "version": "1.0.0",
  "description": "Сайт кофейни «Зерно» — учебный проект на Vanilla JS",
  "main": "api/index.js",
  "scripts": {
    "start": "node api/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "coffeeshop",
    "vanilla-js",
    "учебный-проект"
  ],
  "author": "Студент",
  "license": "MIT",
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/*.test.js"
    ],
    "collectCoverageFrom": [
      "app.js"
    ],
    "coverageReporters": [
      "text",
      "lcov"
    ],
    "coverageThreshold": {
      "global": {
        "functions": 70,
        "lines": 70
      }
    }
  },
  "dependencies": {
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "sqlite3": "^6.0.1"
  }
}
