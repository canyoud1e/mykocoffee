# Токен Telegram-бота, отриманий від @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ID чату або групи, куди бот повинен надсилати замовлення (можна дізнатися у @userinfobot або @raw_data_bot)
TELEGRAM_CHAT_ID=your_chat_id_here

# Пароль для входу в адмін-панель (за замовчуванням 'admin')
ADMIN_PASSWORD=admin

# URL підключення до хмарної бази даних PostgreSQL (наприклад, Supabase або Neon) - необов'язково
# DATABASE_URL=postgres://user:password@host:port/dbname
